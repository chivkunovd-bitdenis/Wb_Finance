# --- Service ---
WIP_ENV=development
WIP_API_HOST=0.0.0.0
WIP_API_PORT=9100

# Redis for Celery (use a dedicated DB index on shared Redis, e.g. /1)
WIP_REDIS_URL=redis://redis:6379/1

# Own DB for jobs/assets (SQLite path or postgresql://...)
# В docker-compose.example: один volume wip_data:/data → и БД, и подкаталог media.
WIP_DATABASE_URL=sqlite:////data/wip_jobs.db

# Files on this service volume (внутри того же /data, что и SQLite)
WIP_MEDIA_ROOT=/data/media

# OpenAI (Q6/Q7 — имена моделей как в дискавери)
WIP_OPENAI_API_KEY=
# Лёгкий шаг: SEO + JSON с 4 промптами главного кадра
WIP_OPENAI_MODEL_STRUCTURE=gpt-4.1-mini
# Пакет из 8 промптов серии (качественнее, чем structure)
WIP_OPENAI_MODEL_PROMPT_PACK=gpt-4.1
# Генерация изображений (актуальное имя модели — по доке OpenAI)
WIP_OPENAI_IMAGE_MODEL=gpt-image-1

# Шаблон промпта для фазы IMAGE (PG-B.1). Должен содержать `{user_text}`. Пустая строка = встроенный дефолт.
WIP_IMAGE_PROMPT_TEMPLATE=
# Макс. длина description_user перед вставкой в шаблон (1…32000, по умолчанию 8000).
WIP_IMAGE_PROMPT_USER_TEXT_MAX_CHARS=8000
# Таймаут HTTP к api.openai.com (секунды, минимум 15)
WIP_OPENAI_TIMEOUT_SEC=120

# Internal verification (until mTLS is wired everywhere)
WIP_INTERNAL_HMAC_SECRET=change-me-in-prod
