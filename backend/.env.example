# Шаблон для git. Реальные ключи — только в файле .env (рядом с этим примером).
#   cp .env.example .env
# На сервере правь backend/.env, НЕ .env.example — приложение не читает .env.example.
# Docker: env_file + монтирование ./backend/.env → /app/.env; после правок .env перезапусти api.

# Ключ доступа к API статистики Wildberries (для интеграционных тестов test_wb_client_real.py)
WB_API_KEY=

# Опционально: артикулы для теста воронки, если за период нет продаж (через запятую)
# WB_FUNNEL_NM_IDS=12345,67890

# ── ЮKassa (оплата подписки) ────────────────────────────────────────────────
# Из личного кабинета ЮKassa: идентификатор магазина + секретный ключ (скопируй целиком, без кавычек).
# Реальный ключ выглядит как test_... или live_... — без символа * в середине (это не маскировка).
# Без пары shop_id + secret API создаёт «mock»-платёж (для разработки).
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Если checkout не передаёт return_url с фронта — запасной URL возврата после оплаты
# YOOKASSA_RETURN_URL=https://your-domain/billing
# Опционально: тот же секрет, что в заголовке X-Webhook-Secret у POST /billing/webhook/yookassa
# YOOKASSA_WEBHOOK_SECRET=
#
# 54‑ФЗ / чек (receipt)
# Если для магазина включены чеки и ЮKassa отвечает 400 "Receipt is missing or illegal" при POST /v3/payments,
# включи формирование receipt на нашей стороне.
# YOOKASSA_REQUIRE_RECEIPT=true
# Ставка НДС для позиции (vat_code). По умолчанию 1 (без НДС).
# YOOKASSA_VAT_CODE=1
# Система налогообложения (tax_system_code). Если ЮKassa потребует — укажи код согласно их настройкам магазина.
# YOOKASSA_TAX_SYSTEM_CODE=

# ── Admin ────────────────────────────────────────────────────────────────────
# Секрет для защищённых admin-эндпоинтов (напр. /billing/admin/grant-lifetime)
# Генерировать: openssl rand -hex 32
ADMIN_SECRET=

# ── AI Daily Brief ──────────────────────────────────────────────────────────
# Включить/выключить функционал ежедневной AI-сводки (и внешние запросы к AI API).
# По умолчанию выключено (если переменная не задана).
DAILY_BRIEF_ENABLED=false

# Ежедневный автозапуск AI-MVP3 (Celery beat): единоразово на пользователя с актуальным конкурентным отчётом.
AI_DAILY_ANALYTICS_BEAT_ENABLED=false
# Период отчёта: week | month | quarter (по умолчанию week)
# AI_DAILY_ANALYTICS_BEAT_PERIOD=week

# ── AI Competitor report (Playwright) ───────────────────────────────────────
# Включить скачивание Excel отчёта сравнения с конкурентами через Playwright (celery_worker).
# Требуются установленные браузеры Playwright внутри окружения worker'а.
AI_COMPETITOR_PLAYWRIGHT_ENABLED=false
#
# Какие периоды скачивать за один подтверждённый запуск refresh (через запятую).
# Например: "week,month" чтобы одним кликом обновлять 2 отчёта.
# По умолчанию скачивается только период, который был запрошен задачей.
AI_COMPETITOR_PLAYWRIGHT_FETCH_PERIODS=week,month
#
# Сценарий (MVP): зайти в раздел со списком сравнений → открыть нужную запись → выбрать период →
# нажать «Создать Excel» → ввести имя → «Сформировать» → открыть «Отчёты» → скачать Excel.
#
# URL раздела со списком записей сравнения карточек.
WB_COMPETITOR_LIST_URL=
#
# Как выбрать нужную запись в списке (в порядке приоритета):
# 1) WB_COMPETITOR_ROW_SELECTOR (точный CSS селектор кликабельной строки/ячейки)
# 2) WB_COMPETITOR_ROW_NM_ID (nm_id/артикул — число)
# 3) WB_COMPETITOR_ROW_TEXT (текст строки/карточки)
WB_COMPETITOR_ROW_SELECTOR=
WB_COMPETITOR_ROW_NM_ID=
#
# Как выбрать нужную запись по тексту: ищем строку/карточку по тексту.
WB_COMPETITOR_ROW_TEXT=
#
# Для поиска строки по nm_id в виртуализованной таблице: сколько шагов скролла делать и на сколько пикселей.
WB_COMPETITOR_SCROLL_STEPS=30
WB_COMPETITOR_SCROLL_PX=900
#
# Внутри найденной строки/карточки: на что кликать, чтобы открыть детальную страницу сравнения.
# Пример: "a" или "button" или "[data-testid='open']" — зависит от WB DOM.
# Если кликабельна вся область строки/карточки — поставь значение `self`.
WB_COMPETITOR_ROW_CLICK_SELECTOR=
#
# Выбор периода в деталке: предпочтительно табы (селекторы для клика).
WB_COMPETITOR_PERIOD_TAB_SELECTOR_TODAY=
WB_COMPETITOR_PERIOD_TAB_SELECTOR_WEEK=
WB_COMPETITOR_PERIOD_TAB_SELECTOR_MONTH=
WB_COMPETITOR_PERIOD_TAB_SELECTOR_QUARTER=
# Фоллбек: если табы не заданы, пытаемся кликнуть по видимому тексту (можно переопределить)
WB_COMPETITOR_PERIOD_TAB_LABEL_TODAY=Сегодня
WB_COMPETITOR_PERIOD_TAB_LABEL_WEEK=Неделя
WB_COMPETITOR_PERIOD_TAB_LABEL_MONTH=Месяц
WB_COMPETITOR_PERIOD_TAB_LABEL_QUARTER=Квартал
# Last resort (старый режим): dropdown + тексты опций
WB_COMPETITOR_PERIOD_DROPDOWN_SELECTOR=
WB_COMPETITOR_PERIOD_OPTION_TEXT_WEEK=
WB_COMPETITOR_PERIOD_OPTION_TEXT_MONTH=
WB_COMPETITOR_PERIOD_OPTION_TEXT_QUARTER=
#
# Сформировать Excel: кнопка (иконка), input названия, кнопка подтверждения, открыть "Отчёты", и скачать.
WB_COMPETITOR_CREATE_EXCEL_SELECTOR=
WB_COMPETITOR_EXCEL_NAME_INPUT_SELECTOR=
WB_COMPETITOR_EXCEL_GENERATE_CONFIRM_SELECTOR=
WB_COMPETITOR_REPORTS_BUTTON_SELECTOR=
WB_COMPETITOR_REPORT_DOWNLOAD_BUTTON_SELECTOR=
#
# Опционально: путь к storage_state (cookies/localStorage) для обхода логина/2FA.
# Сгенерируй файл один раз вручную и храни как секрет (НЕ в git).
WB_PLAYWRIGHT_STORAGE_STATE_PATH=/run/secrets/wb_storage_state.json

# Ключ OpenAI-совместимого API для ежедневной AI-сводки.
# Поддерживает любой провайдер с /chat/completions (OpenAI, Azure, Deepseek, etc.)
AI_API_KEY=

# Base URL провайдера (без /v1/chat/completions).
# По умолчанию: https://api.openai.com/v1
# Пример для Deepseek: https://api.deepseek.com/v1
AI_API_BASE_URL=https://api.openai.com/v1

# Модель для сводки. По умолчанию: gpt-4o-mini
# gpt-4o-mini — быстро, дёшево, достаточно для ежедневного отчёта
AI_MODEL=gpt-4o-mini

# Таймаут вызова AI в секундах (по умолчанию 120)
AI_TIMEOUT_SEC=120

# Максимальное количество токенов в ответе (по умолчанию 900)
AI_MAX_TOKENS=900

# ── ИИ: полная генерация товара (референсы PG-2.2) ───────────────────────────
# Каталог на диске API для сохранения изображений-референсов (persist: ./backend/data в Docker).
# PRODUCT_GENERATION_REFERENCES_DIR=/app/data/product_generation_references
# Лимиты (опционально): PRODUCT_GENERATION_REFERENCE_MAX_BYTES, PRODUCT_GENERATION_REFERENCE_MAX_FILES

# Локальный запуск без Docker: перед uvicorn из каталога backend выполни:
#   alembic upgrade heads
