# Копируй в .env и подставь свой ключ: cp .env.example .env
# Файл .env в git не попадает — ключ остаётся только у тебя.

# Ключ доступа к API статистики Wildberries (для интеграционных тестов test_wb_client_real.py)
WB_API_KEY=

# Опционально: артикулы для теста воронки, если за период нет продаж (через запятую)
# WB_FUNNEL_NM_IDS=12345,67890

# ── ЮKassa (оплата подписки) ────────────────────────────────────────────────
# Из личного кабинета ЮKassa: идентификатор магазина + секретный ключ.
# Без них API создаёт «mock»-платёж (для разработки).
YOOKASSA_SHOP_ID=1312187
YOOKASSA_SECRET_KEY=test_*gmnxdVYh17yrFzRSH7DSPHGkSozUbopJMeFoXqQ8HKqM
# Если checkout не передаёт return_url с фронта — запасной URL возврата после оплаты
# YOOKASSA_RETURN_URL=https://your-domain/billing
# Опционально: тот же секрет, что в заголовке X-Webhook-Secret у POST /billing/webhook/yookassa
# YOOKASSA_WEBHOOK_SECRET=

# ── Admin ────────────────────────────────────────────────────────────────────
# Секрет для защищённых admin-эндпоинтов (напр. /billing/admin/grant-lifetime)
# Генерировать: openssl rand -hex 32
ADMIN_SECRET=

# ── AI Daily Brief ──────────────────────────────────────────────────────────
# Включить/выключить функционал ежедневной AI-сводки (и внешние запросы к AI API).
# По умолчанию выключено (если переменная не задана).
DAILY_BRIEF_ENABLED=false

# Ключ OpenAI-совместимого API для ежедневной AI-сводки.
# Поддерживает любой провайдер с /chat/completions (OpenAI, Azure, Deepseek, etc.)
AI_API_KEY=

# Base URL провайдера (без /v1/chat/completions).
# По умолчанию: https://api.openai.com/v1
# Пример для Deepseek: https://api.deepseek.com/v1
AI_API_BASE_URL=https://api.openai.com/v1

# Модель для сводки. По умолчанию: gpt-4o-mini
# gpt-4o-mini — быстро, дёшево, достаточно для ежедневного отчёта
AI_MODEL=gpt-4o-mini

# Таймаут вызова AI в секундах (по умолчанию 120)
AI_TIMEOUT_SEC=120

# Максимальное количество токенов в ответе (по умолчанию 900)
AI_MAX_TOKENS=900

# Локальный запуск без Docker: перед uvicorn из каталога backend выполни:
#   alembic upgrade heads
