# Ключи и секреты — не коммитить
.env
backend/.env
*.env
!.env.example
!backend/.env.example

# macOS metadata (не должны попадать в архивы и на сервер)
.DS_Store
**/.DS_Store
._*
**/._*

# Python
**/__pycache__/
**/*.pyc
**/*.pyo

# Node / frontend build artifacts
**/node_modules/
frontend/dist/
frontend/test-results/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
